void updateStock()
{
    int id,i,qty;

    printf("Product ID: ");
    scanf("%d",&id);

    for(i=0;i<count;i++)
    {
        if(product[i].id==id)
        {
            printf("Add Quantity: ");
            scanf("%d",&qty);

            product[i].quantity+=qty;

            saveData();

            printf("Stock Updated\n");
            return;//what does this return means?//
        }
    }

    printf("Product Not Found\n");
}

void deleteProduct()
{
    int id,i,j;

    printf("Product ID: ");
    scanf("%d",&id);

    for(i=0;i<count;i++)
    {
        if(product[i].id==id)
        {
            for(j=i;j<count-1;j++)
            {
                product[j]=product[j+1];
            }

            count--;

            saveData();

            printf("Product Deleted\n");
            return;
        }
    }

    printf("Product Not Found\n");
}

void lowStock()
{
    int i;

    printf("\nLow Stock Items (less than five )\n");

    for(i=0;i<count;i++)
    {
        if(product[i].quantity<5)
        {
            printf("%s (%d left)\n",
            product[i].name,
            product[i].quantity);
        }
    }
}

void salesReport()
{
    printf("Total Sales: %.2f\n",totalSales);
}

void searchProduct()
{
    int id,i;

    printf("Enter ID: ");
    scanf("%d",&id);

    for(i=0;i<count;i++)
    {
        if(product[i].id==id)
        {
            printf("Found: %s Price %.2f Stock %d\n",
            product[i].name,
            product[i].price,
            product[i].quantity);
            return;
        }
    }

    printf("Not Found\n");
}

void buyProduct()
{
    int id,i,qty;
    float total;

    printf("Product ID: ");
    scanf("%d",&id);

    printf("Quantity: ");
    scanf("%d",&qty);

    for(i=0;i<count;i++)
    {
        if(product[i].id==id)
        {
            if(product[i].quantity>=qty)
            {
                total=product[i].price*qty;

                if(userPoints>=1000)
                {
                    total=total-(total*0.05);
                    printf("5%% Discount Applied\n");
                    userPoints-=1000;
                }

                product[i].quantity-=qty;

                printf("Total Price %.2f\n",total);

                if(total>=500)
                {
                    userPoints+=1000;
                    printf("You got 1000 points\n");
                }

                totalSales+=total;



                saveData();

                return;
            }
            else
            {
                printf("Not Enough Stock\n");
                return;
            }
        }
    }

    printf("Product Not Found\n");
}

void returnProduct()
{
    int id,i,qty;

    printf("Product ID: ");
    scanf("%d",&id);

    printf("Quantity: ");
    scanf("%d",&qty);

    for(i=0;i<count;i++)
    {
        if(product[i].id==id)
        {
            product[i].quantity+=qty;

            saveData();

            printf("Return Successful\n");
            return;
        }
    }

    printf("Product Not Found\n");
}

void saveData()
{
    FILE *fp;

    fp=fopen("inventory.txt","wb");

    if(fp==NULL) return;

    fwrite(&count,sizeof(int),1,fp);
    fwrite(&totalSales,sizeof(float),1,fp);
    fwrite(&userPoints,sizeof(int),1,fp);
    fwrite(product,sizeof(struct Product),count,fp);

    fclose(fp);
}

void loadData()
{
    FILE *fp;

    fp=fopen("inventory.txt","rb");

    if(fp==NULL) return;

    fread(&count,sizeof(int),1,fp);
     fread(&totalSales,sizeof(float),1,fp);
      fread(&userPoints,sizeof(int),1,fp);
    fread(product,sizeof(struct Product),count,fp);

    fclose(fp);
}


