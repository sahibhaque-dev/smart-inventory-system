void addProduct()
{
    printf("Product ID: ");
    scanf("%d",&product[count].id);
    getchar();  //to avoid buffer

    printf("Product Name: ");
    fgets(product[count].name,50,stdin);
    product[count].name[strcspn(product[count].name,"\n")]='\0';

    printf("Product Price: ");
    scanf("%f",&product[count].price);

    printf("Product Quantity: ");
    scanf("%d",&product[count].quantity);

    count++;

    saveData();

    printf("\t<==Product Added Successfully==>\n");

}
void viewProduct()
{
    int i;

    if(count==0)
        printf("\t<==No product Found==>\n");
    else
    {
        printf("\tID\t\tName\t\tPrice\t\tQuantity");
        for(i=0;i<count;i++)
        {
            printf("\n\t%d\t\t%s\t%.2f\t\t%d",product[i].id,product[i].name,product[i].price,product[i].quantity);

        }
    }
}

